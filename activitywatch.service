[Unit]
Description=ActivityWatch - Activity tracking service
StartLimitIntervalSec=60
StartLimitBurst=5
After=graphical-session.target
Wants=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/bash $HOME/.local/bin/activitywatch_start.sh
Restart=on-failure
RestartSec=10
PassEnvironment=DISPLAY XAUTHORITY WAYLAND_DISPLAY DBUS_SESSION_BUS_ADDRESS XDG_RUNTIME_DIR

[Install]
WantedBy=default.target
